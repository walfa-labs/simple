# Server Configuration
SERVER_PORT=8080

# PostgreSQL Configuration (optional - leave empty to disable)
# For production, set POSTGRES_SSLMODE=require
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=simple
# POSTGRES_SSLMODE=disable  # Options: disable, require, verify-ca, verify-full

# Redis Configuration (optional - leave empty to disable)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_SSL=true  # Enable for production with SSL

# MongoDB Configuration (optional - leave empty to disable)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=mongo
MONGO_PASSWORD=mongo
MONGO_DB=simple
# MONGO_SSL=true  # Enable for production with SSL
